#       - uses: actions/setup-python@v5
#         with:
#           python-version: "3.11"
#       - name: Installer les dépendances
#         run: |
#           python -m pip install --upgrade pip
#           pip install -r requirements.txt
#       - name: Lint (flake8)
#         run: flake8 app/
#       - name: Tests pytest + couverture
#         run: pytest --cov=app --cov-report=term-missing
#       # Approfondissement : faire échouer si la couverture < seuil
#       # run: pytest --cov=app --cov-fail-under=70
#
#   e2e:
#     runs-on: ubuntu-latest
#     steps:
#       - uses: actions/checkout@v4
#       - uses: actions/setup-python@v5
#         with:
#           python-version: "3.11"
#       - uses: actions/setup-node@v4
#         with:
#           node-version: "20"
#       - name: Démarrer le backend
#         working-directory: backend
#         run: |
#           python -m pip install --upgrade pip
#           pip install -r requirements.txt
#           python seed.py
#           nohup uvicorn app.main:app --port 8000 &
#       - name: Installer le frontend
#         working-directory: frontend
#         run: npm ci
#       - name: Lint (ESLint)
#         working-directory: frontend
#         run: npm run lint
#       - name: Tests Cypress (headless)
#         working-directory: frontend
#         run: |
#           npm run dev &
#           # Attendre que le frontend ET le backend répondent avant de lancer
#           # Cypress (sinon les tests échouent aléatoirement au démarrage).
#           npx wait-on http://localhost:5173 http://localhost:8000/api/v1/health
#           npx cypress run
#
# # Pistes d'approfondissement (4A attendu / 5A bonus) :
# #   - quality gate chiffré (couverture minimale)
# #   - badge de build dans le README
# #   - branches protégées (PR validée par la CI avant merge sur main)
# #   - déploiement continu du frontend sur merge vers main
