# ─── Base de données ───
DATABASE_URL=sqlite:///./padel_corpo.db

# ─── Sécurité ───
# En production : générer une clé aléatoire (ex. `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=dev-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ───
ALLOWED_ORIGINS=http://localhost:5173

# ─── Upload photos de profil ───
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=2097152
